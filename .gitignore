# ============================================================
# NegotiationForge .gitignore
# 覆盖范围：Python 后端 / Node.js 前端 / 环境变量 / 编辑器
# ============================================================

# ------------------------------------------------------------
# 环境变量（绝对不能提交）
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 虚拟环境
.venv/
venv/
env/
ENV/

# 构建产物
*.egg-info/
dist/
build/
*.egg

# 测试 / 覆盖率
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# mypy / ruff / pyright
.mypy_cache/
.ruff_cache/
pyrightconfig.json

# uv
.uv/

# SQLite 数据库文件（开发阶段本地数据）
*.db
*.sqlite
*.sqlite3

# ------------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------------
node_modules/
.next/
out/
.vercel/
.turbo/

frontend/dist/
frontend/build/

yarn.lock
pnpm-lock.yaml

# ------------------------------------------------------------
# 编辑器 / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.cursor/

# ------------------------------------------------------------
# 日志
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*

# ------------------------------------------------------------
# 其他
# ------------------------------------------------------------
scratch/
tmp/
