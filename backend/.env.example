# NegotiationForge backend environment variables
# Copy this file to .env and replace the placeholder values.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# LLM provider selection
# Supported values: deepseek | openai | gemini
# -----------------------------------------------------------------------------
LLM_PROVIDER=deepseek

# -----------------------------------------------------------------------------
# DeepSeek
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# OpenAI compatible
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Gemini
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Database
# SQLite for local development
# Example PostgreSQL DSN:
# postgresql+asyncpg://user:password@host:5432/dbname
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./negotiationforge.db
